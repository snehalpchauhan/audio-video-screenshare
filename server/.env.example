# ─── Server ──────────────────────────────────────────────────
PORT=5001
NODE_ENV=production

# ─── Database (PostgreSQL) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=voicelink
DB_PASSWORD=your_db_password_here
DB_NAME=voicelink

# ─── JWT Secrets (change these in production!) ───────────────
JWT_SECRET=change-this-to-a-long-random-string-in-production
SESSION_SECRET=change-this-to-another-long-random-string-in-production
